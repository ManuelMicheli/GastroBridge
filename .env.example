# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_RESTAURANT_PRO=
STRIPE_PRICE_RESTAURANT_BUSINESS=
STRIPE_PRICE_SUPPLIER_BASE=
STRIPE_PRICE_SUPPLIER_GROWTH=
STRIPE_PRICE_SUPPLIER_ENTERPRISE=

# Meilisearch
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Web Push / VAPID
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@gastrobridge.it
# Same value as VAPID_PUBLIC_KEY, exposed to the client service worker
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# HMAC secret for customer confirmation tokens (supplier modified orders)
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Shared secret for cron-invoked endpoints (e.g., /api/search/sync/queue).
# Expected as X-Cron-Token header. Generate with: openssl rand -base64 32
CRON_SECRET=
